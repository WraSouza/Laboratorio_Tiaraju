    <FlyoutItem Title="RH" Icon="rhicon.png">
        <ShellContent ContentTemplate="{DataTemplate pages:RHView}"/>
        <!--<ShellContent Title="Pauta Fixa" Icon="notes.png" ContentTemplate="{DataTemplate pages:RHView}"/>
        <ShellContent Title="Informativo Covid" Icon="virus.png" ContentTemplate="{DataTemplate pages:InformativoCovidView}"/>-->
    </FlyoutItem>

    <FlyoutItem Title="TI" Icon="tiicon.png">
        <ShellContent ContentTemplate="{DataTemplate pages:TIView}"/>
    </FlyoutItem>  


</Shell>