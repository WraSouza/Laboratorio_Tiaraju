                                    </StackLayout.GestureRecognizers>
                                </StackLayout>
                            </Grid>
                        </Grid>                           
                    </StackLayout>                    
                </ScrollView>                   
                    
                </StackLayout>

            <StackLayout Grid.Column="0" Grid.Row="3">
                <Label Text="Serviços"
                       TextColor="Black"
                       FontSize="20"
                       FontFamily="MontserratBold"
                       Margin="0,20,0,0"/>
            </StackLayout>
            
            <!--Serviços-->
            <StackLayout Orientation="Horizontal" Grid.Column="0" Grid.Row="4">
                <ScrollView Orientation="Horizontal">
                    <StackLayout>
                        <!--Abertura de Chamado-->
                        <Grid ColumnDefinitions="180,180,180" RowDefinitions="200">
                            <Grid Grid.Column="0">
                                <Image Source="tilogo.jpg"
                                       Aspect="Fill"/>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="Abertura de Chamado"
                           VerticalOptions="EndAndExpand"
                           HorizontalOptions="StartAndExpand"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"/>
                                    <StackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenChamado}"/>
                                    </StackLayout.GestureRecognizers>
                                </StackLayout>
                            </Grid>

                            <!--Aniversariantes-->
                            <Grid Grid.Column="1">
                                <Image Source="cardapiologo.jpg"
                                            Aspect="Fill"/>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="Cardápio Semanal"
                                               VerticalOptions="EndAndExpand"
                                               HorizontalOptions="StartAndExpand"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                    <StackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenCardapioView}"/>
                                    </StackLayout.GestureRecognizers>
                                </StackLayout>
                            </Grid>

                            <!--Prevenção COVID-->
                            <Grid Grid.Column="2">
                                <Image Source="cardapiologo.jpg"
                                            Aspect="Fill"/>
                                <StackLayout Orientation="Horizontal">
                                    <Label Text="Prevenção COVID"
                                               VerticalOptions="EndAndExpand"
                                               HorizontalOptions="StartAndExpand"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="White"/>
                                    <StackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenCardapioView}"/>
                                    </StackLayout.GestureRecognizers>
                                </StackLayout>
                            </Grid>
                        </Grid>
                    </StackLayout>
                </ScrollView>

            </StackLayout>




